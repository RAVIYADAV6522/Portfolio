# Template only — do not commit real secrets. For production, set the variable in
# Vercel (Project → Settings → Environment Variables), not by pasting into this file.
#
# Local dev (optional): copy to ".env.local" and use your real URL so OG metadata
# matches; .env.local is gitignored.
#
# Value: https URL, no trailing slash (e.g. https://your-name.vercel.app)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
